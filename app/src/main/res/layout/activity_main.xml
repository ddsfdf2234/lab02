<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">


        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Как вы себя чувствуете?"
            android:textSize="24sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Оценка настроения:"
            android:textSize="18sp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"/>


        <LinearLayout
            android:id="@+id/starRatingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/star1"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/star_off"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/star2"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/star_off"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/star3"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/star_off"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/star4"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/star_off"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"/>

            <ImageButton
                android:id="@+id/star5"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/star_off"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"/>

        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Комментарий:"
            android:textSize="18sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/commentEditText"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Введите ваш комментарий здесь..."
            android:gravity="top"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:inputType="textMultiLine"
            android:layout_marginBottom="24dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/clearButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Очистить"
                android:textSize="16sp"
                android:backgroundTint="#F44336"
                android:layout_marginRight="8dp"/>

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сохранить"
                android:textSize="16sp"
                android:backgroundTint="#4CAF50"
                android:layout_marginLeft="8dp"/>

        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статистика за неделю"
            android:textSize="20sp"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>


        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:rowCount="2"
            android:background="#E0E0E0">


            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Пн"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Вт"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Ср"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Чт"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Пт"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Сб"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="Вс"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#BDBDBD"
                android:layout_columnWeight="1"
                android:padding="8dp"/>


            <TextView
                android:id="@+id/mondayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="4"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#FFCDD2"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/tuesdayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="3"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#FFE0B2"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/wednesdayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="5"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#C8E6C9"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/thursdayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="2"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#FFCDD2"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/fridayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="4"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#FFE0B2"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/saturdayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="5"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#C8E6C9"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/sundayValue"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:text="4"
                android:textSize="14sp"
                android:gravity="center"
                android:background="#FFE0B2"
                android:layout_columnWeight="1"
                android:padding="8dp"/>

        </GridLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Цве показывает оценку настроения (1-5)"
            android:textSize="12sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

</ScrollView>